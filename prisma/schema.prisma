// prisma/schema.prisma
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  warehouses       Warehouse[]
  products         Product[]
  users            User[]
  materialRequests MaterialRequest[]
}

model Warehouse {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  inventoryItems   InventoryItem[]
  movementsFrom    StockMovement[]   @relation("FromWarehouse")
  movementsTo      StockMovement[]   @relation("ToWarehouse")
  materialRequests MaterialRequest[]

  @@unique([name, organizationId])
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String
  name           String
  role           String       @default("USER_MP") // "ADMIN_MP" | "USER_MP"
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  movements         StockMovement[]
  requestsCreated   MaterialRequest[] @relation("Requester")
  requestsPrepared  MaterialRequest[] @relation("Preparer")
}

model Product {
  id             String       @id @default(uuid())
  name           String
  sku            String?
  unit           String       @default("pza")
  description    String?
  price          Decimal?     @db.Decimal(10, 2)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  inventoryItems InventoryItem[]
  movements      StockMovement[]
  requestItems   MaterialRequestItem[]

  @@index([organizationId])
}

model InventoryItem {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Int       @default(0)
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model StockMovement {
  id              String     @id @default(uuid())
  type            String     // "ENTRY" | "EXIT" | "TRANSFER" | "RETURN"
  productId       String
  product         Product    @relation(fields: [productId], references: [id])
  fromWarehouseId String?
  fromWarehouse   Warehouse? @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String?
  toWarehouse     Warehouse? @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  quantity        Int
  reason          String?
  notes           String?
  receiverName    String?
  trackingNumber  String?
  createdById     String
  createdBy       User       @relation(fields: [createdById], references: [id])
  createdAt       DateTime   @default(now())

  // Link de trazabilidad hacia la solicitud que disparó este movimiento
  requestId String?
  request   MaterialRequest? @relation(fields: [requestId], references: [id])

  @@index([productId])
  @@index([createdById])
  @@index([createdAt])
  @@index([requestId])
}

// === Solicitudes de material ===

model MaterialRequest {
  id             String       @id @default(uuid())
  folio          String       @unique // SOL-2026-0001
  requesterId    String
  requester      User         @relation("Requester", fields: [requesterId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  warehouseId    String
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id])

  // Estado y entrega
  status         String   @default("PENDING") // PENDING | PREPARING | READY | SHIPPED | DELIVERED | CANCELLED
  deliveryMethod String   // PICKUP | SHIPPING

  // Sólo si SHIPPING
  shippingAddress String?
  trackingNumber  String?

  // Datos del destinatario / contacto
  receiverName  String?
  receiverPhone String?

  notes String?

  // Workflow timestamps + actor
  preparedById   String?
  preparedBy     User?     @relation("Preparer", fields: [preparedById], references: [id])
  preparedAt     DateTime?
  fulfilledAt    DateTime? // SHIPPED si shipping, READY si pickup
  deliveredAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?

  items     MaterialRequestItem[]
  movements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([requesterId])
  @@index([organizationId])
  @@index([createdAt])
}

model MaterialRequestItem {
  id                String          @id @default(uuid())
  requestId         String
  request           MaterialRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  quantityRequested Int
  quantityFulfilled Int             @default(0)

  @@unique([requestId, productId])
}
